{
  "name": "mezanino-imobiliaria-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:cms": "node ../cms-imobiliaria/scripts/build-okf.mjs && node scripts/sync-cms.mjs",
    "build": "npm run sync:cms && node --env-file=.env scripts/build-web.mjs",
